{
  "name": "catalogo-cruzeiro-do-sul",
  "version": "1.0.0",
  "private": true,
  "description": "Catálogo Cruzeiro do Sul - portal local com agregador e serviços",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "agents:cycle": "node scripts/agents-autonomy-cycle.js --once",
    "agents:daemon": "node scripts/agents-autonomy-cycle.js --daemon",
    "agents:run": "node scripts/real-agents-runtime.js",
    "audit:news-images": "node scripts/audit-news-image-focus.js",
    "codex:health": "node scripts/codex-health-check.js",
    "cleanup:audit": "node scripts/cleanup-extreme-audit.js",
    "deploy:storage-check": "node scripts/check-render-storage.js",
    "dns:check": "node scripts/check-dns-readiness.js",
    "editorial:health": "node scripts/editorial-health-check.js",
    "memory:ensure": "node scripts/codex-memory.js ensure",
    "memory:status": "node scripts/codex-memory.js status",
    "perf:budget": "node scripts/performance-budget-check.js",
    "guard:pubpaid": "node scripts/guard-pubpaid-no-canvas.js",
    "review:team": "node scripts/guard-pubpaid-no-canvas.js && node scripts/review-team-audit.js",
    "rayx:chrome:profiles": "node rayx/core/chrome-profiles.js",
    "rayx:dashboard": "node rayx/core/dashboard.js",
    "rayx:doctor": "node rayx/core/doctor.js --pretty",
    "rayx:doctor:save": "node rayx/core/doctor.js --pretty --out .codex-temp/rayx-doctor/latest.json",
    "rayx:shell": "node rayx/core/shell.js",
    "rayx:status": "node rayx/core/status.js",
    "start": "node server.js",
    "sync:online-local": "node scripts/sync-online-local.js"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "pdfkit": "^0.17.2",
    "phaser": "^3.90.0",
    "qrcode": "^1.5.4"
  },
  "engines": {
    "node": ">=18"
  }
}
